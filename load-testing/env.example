# Base URL for k6 (must reach Laravel API through nginx)
# From host OS (k6 installed locally):
#   K6_BASE_URL=http://localhost/api
# From k6 Docker container (see Makefile load-test):
#   K6_BASE_URL=http://host.docker.internal/api

K6_BASE_URL=http://localhost/api

# Tenant A — يُفضّل شركة المحاكاة (عملاء + منتجات جاهزة من DemoOperationsSeeder)
K6_EMAIL_A=simulation.owner@demo.local
K6_PASSWORD_A=SimulationDemo123!

# Tenant B — شركة مختلفة لاختبارات عزل البيانات (Demo Auto Center)
K6_EMAIL_B=owner@demo.sa
K6_PASSWORD_B=password

# --- سعة POS (K6_PROFILE=capacity_pos) — استكشافي، ليس بوابة قبول ---
# معدّل وصول ثابت (بيع/ثانية تقريباً) بعد هضم قصير
K6_CAPACITY_POS_RATE=3
# مدة الثبات عند المعدّل المستهدف (دقائق)
K6_CAPACITY_POS_STEADY_MIN=5
# اختياري: K6_CAPACITY_POS_RAMP=30s  K6_CAPACITY_POS_TAIL=25s
# اختياري: K6_CAPACITY_POS_PRE_VUS / K6_CAPACITY_POS_MAX_VUS
# توزيع عملاء POS: single | multi (انظر k6/lib/api-scenarios.js)
K6_POS_DISTRIBUTION=single
# سلم bash: معدلات مفصولة بفاصلة
# K6_CAPACITY_LADDER_RATES=3,5,7
