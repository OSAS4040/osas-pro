# انسخ هذا الملف إلى `.env` عند جذر المشروع (مستبعد من git).
#
# ── ngrok (ERR_NGROK_3200 = الوكيل غير متصل أو المنفذ المحلي لا يعمل) ──
# 1) NGROK_AUTHTOKEN من https://dashboard.ngrok.com/get-started/your-authtoken
# 2) (موصى به) NGROK_DOMAIN = دومين محجوز من لوحة ngrok (Domains / Reserved)
#    ثابت في كل إعادة تشغيل — نفس الرابط في المتصفح.
# 3) make up-ngrok   ← يشغّل الخدمات + النفق
# 4) make ngrok-url  ← يطبع الرابط و VITE_DEV_PUBLIC_HOST لـ frontend/.env
#
NGROK_AUTHTOKEN=
# مثال (بدون https://): lynette-fluviatile-jarod.ngrok-free.dev
NGROK_DOMAIN=
