APP_NAME="SaaS POS ERP"
APP_ENV=local
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate
APP_DEBUG=true
# Demo seeders run automatically in local/testing.
# On other environments they are skipped unless enabled explicitly.
# APP_DEMO_DATA_ENABLED=false
# Production safety for DefaultAdminSeeder:
# APP_DEFAULT_ADMIN_SEEDER=false
# APP_DEFAULT_ADMIN_PASSWORD=
APP_URL=http://localhost
# رابط عام يفتح من المتصفح (QR، واتساب، بريد). اضبطه في الإنتاج إذا كان APP_URL داخلياً (مثل http://nginx).
APP_PUBLIC_URL=

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=saas_db
DB_USERNAME=saas_user
DB_PASSWORD=saas_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

SENTRY_LARAVEL_DSN=

LOG_CHANNEL=stack
LOG_LEVEL=debug

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@saas-pos.com"
MAIL_FROM_NAME="${APP_NAME}"
