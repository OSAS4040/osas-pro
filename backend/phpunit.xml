<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>

    <php>
        <env name="APP_ENV"          value="testing" force="true"/>
        <env name="APP_KEY"          value="base64:YourTestKeyHere32BytesLongString=" force="true"/>
        <env name="APP_CONFIG_CACHE" value="/tmp/laravel-testing-config.php" force="true"/>
        <env name="APP_EVENTS_CACHE" value="/tmp/laravel-testing-events.php" force="true"/>
        <env name="APP_ROUTES_CACHE" value="/tmp/laravel-testing-routes.php" force="true"/>
        <env name="APP_SERVICES_CACHE" value="/tmp/laravel-testing-services.php" force="true"/>
        <env name="DB_CONNECTION"    value="pgsql" force="true"/>
        <env name="DB_DATABASE"      value="saas_test" force="true"/>
        <env name="DB_USERNAME"      value="saas_user" force="true"/>
        <env name="DB_PASSWORD"      value="saas_password" force="true"/>
        <env name="DB_HOST"          value="postgres" force="true"/>
        <env name="DB_PORT"          value="5432" force="true"/>
        <env name="CACHE_DRIVER"     value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="WHATSAPP_WORK_ORDER_NOTIFICATIONS_ENABLED" value="true" force="true"/>
        <env name="SESSION_DRIVER"   value="array" force="true"/>
        <env name="MAIL_MAILER"      value="array" force="true"/>
        <env name="REDIS_HOST"       value="redis" force="true"/>
        <env name="BCRYPT_ROUNDS"    value="4" force="true"/>
    </php>
</phpunit>
