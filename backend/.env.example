APP_NAME="SaaS POS ERP"
APP_ENV=local
# فارغ أولاً ثم: php artisan key:generate — لا تشارك القيمة ولا تلصق مفاتيح من git في الإنتاج.
# مع Docker: الحاويات تقرأ هذا الملف؛ تأكد أن APP_KEY مُعرّف قبل تشغيل workers/scheduler.
APP_KEY=
APP_DEBUG=true
# Demo seeders run automatically in local/testing.
# On other environments they are skipped unless enabled explicitly.
# APP_DEMO_DATA_ENABLED=false
# Production safety for DefaultAdminSeeder:
# APP_DEFAULT_ADMIN_SEEDER=false
# APP_DEFAULT_ADMIN_PASSWORD=
# مع APP_ENV=production: إن احتجت تشغيل DemoPlatformAdminSeeder على خادم تجريبي، عيّن true (غير مُنصح للإنتاج العام).
# APP_DEMO_PLATFORM_ADMIN=false
#
# تجاوز كلمة المرور للتطوير المحلي فقط (يتطلب APP_ENV=local و APP_DEBUG=true) — لا تُفعّل على أي خادم مكشوف.
# AUTH_DEV_PASSWORDLESS=false
# AUTH_DEV_PASSWORDLESS_EMAILS=platform-demo@osas.sa
APP_URL=http://localhost
# نطاق الواجهة العامة كما يراه المستخدم (HTTPS في الإنتاج). يُستخدم لبناء روابط QR:
# - هوية المركبة OSAS Pro: /v/{token}
# - روابط أخرى عامة (مشاركة، تحقق) إذا استخدمت config(app_urls.public_base)
# إذا كان APP_URL يشير لخادم داخلي (مثل http://nginx) فضلاً عيّن هنا نطاق التطبيق الفعلي (مثل https://app.example.com).
APP_PUBLIC_URL=

# عنوان الواجهة التي يفتحها المتصفح (Vite dev / nginx / نطاق الإنتاج).
# يُستخدم لإعادة توجيه روابط مثل /landing عند فتحها على منفذ Laravel فقط (مثلاً :8000).
FRONTEND_PUBLIC_URL=http://localhost:5173

# ── مطابقة نشر الواجهة (dist) — اضبطها في CI/Docker عند الإصدار ──
APP_RELEASE_VERSION=1.0.1
APP_RELEASE_COMMIT=unknown
APP_RELEASE_BRANCH=unknown
# ISO-8601 (مثل 2026-04-01T12:00:00.000Z) — نفس لحظة بناء الواجهة
# APP_RELEASE_BUILD_TIME=
APP_RELEASE_ENV=local

# false موصى به مع php-fpm تحت حمل POS متزامن (اتصال دائم يسبب أعطالاً عشوائية). true فقط إذا فهمت التأثير.
DB_PERSISTENT=false
DB_CONNECTION=pgsql
# محلي بدون Docker: 127.0.0.1 — مع Docker Compose استخدم postgres (اسم الخدمة)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=saas_db
DB_USERNAME=saas_user
DB_PASSWORD=

# Testing isolation (prevents php artisan test from touching local app DB)
# اترك الحقول الفارغة داخل Docker ليُورَّث من DB_* (مثلاً DB_HOST=postgres). على الجهاز المضيف ضع 127.0.0.1 إن لزم.
TEST_DB_HOST=
TEST_DB_PORT=
TEST_DB_DATABASE=saas_test
TEST_DB_USERNAME=
TEST_DB_PASSWORD=

# محلي: 127.0.0.1 — Docker: redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
# Dedicated POS / latency-sensitive jobs: docker compose service `queue_pos` runs
# `php artisan queue:work redis --queue=pos --tries=3 --timeout=60` (see docker-compose.yml).
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Incident / queue observability (operations) ─────────────────────
# true = stop scheduler from enqueueing ExpireInventoryReservationsJob + ExpireIdempotencyKeysJob only.
# Financial paths are not gated here; set on the incident host then: php artisan queue:restart
# INCIDENT_CONTAIN_HOUSEKEEPING_JOBS=false
# Log first-attempt queue exceptions for watchlisted jobs (see LogIncidentScopeQueueExceptions).
# QUEUE_INCIDENT_EXCEPTION_LOG_ENABLED=true

# ── إشعارات واتساب لأوامر العمل (تشغيل / حوادث) ───────────────────
# false = لا يُصدَر NotifyCustomerWorkOrderWhatsAppJob عند تسليم/إكمال أمر العمل،
#         وأي job قديمة في الطابور تخرج بهدوء دون فشل أو إعادة محاولة.
# WHATSAPP_WORK_ORDER_NOTIFICATIONS_ENABLED=true

# ── OSAS bulk work orders (POST /api/v1/work-orders/bulk) ─────────────
# Chunk size per queued job (10–200). Default 50.
# WORK_ORDER_BULK_CHUNK_SIZE=50
# Max vehicles per bulk request (1–5000). Default 500.
# WORK_ORDER_BULK_MAX_VEHICLES=500
# Queue name for chunk jobs (default queue).
# WORK_ORDER_BULK_QUEUE=default

# ── مراقبة العمليات (إنتاج) ───────────────────────────────────────
# فشل ترحيل القيد المحاسبي يُسجَّل كـ critical بمفتاح: ledger.alert.ledger_posting_failed
# (مع code=LEDGER_POST_FAILED، company_id، invoice_id، trace_id). اضبط قنوات السجلات/التنبيهات لالتقاطها.
# اختياري: إرسال JSON إلى ويبهوك عند هذا السطر فقط (Slack/Teams/مخصص) — انظر config/ledger_alerts.php
LEDGER_ALERT_WEBHOOK_URL=
LEDGER_ALERT_WEBHOOK_SECRET=
LEDGER_ALERT_TIMEOUT=5

# ZATCA: true = تسجيل محلي فقط (افتراضي آمن)؛ false يتطلب تكاملاً إنتاجياً فعلياً
ZATCA_SIMULATION_MODE=true

# ── OCR / Tesseract (مسح اللوحة، فواتير، مستندات) ─────────────────
# true = تفعيل استدعاء Tesseract من Laravel (افتراضي: مفعّل)
OCR_ENABLED=true
# اتركه فارغاً للاكتشاف التلقائي (/usr/bin/tesseract في Docker Alpine عادةً)
OCR_TESSERACT_PATH=
OCR_DEFAULT_LANG_PLATE=eng+ara
OCR_DEFAULT_LANG_DOCUMENT=ara+eng
OCR_TIMEOUT_SECONDS=90
OCR_MAX_IMAGE_BYTES=12582912
# للتحقق عبر: php artisan ocr:verify
OCR_REQUIRED_LANGS=ara,eng

# ── Intelligence / domain events (Asas Pro) ─────────────────────────
INTELLIGENT_EVENTS_ENABLED=false
INTELLIGENT_EVENTS_PERSIST_ENABLED=false
INTELLIGENT_OBSERVABILITY_ENABLED=false

INTELLIGENT_INTERNAL_DASHBOARD_ENABLED=false
INTELLIGENT_READ_MODELS_ENABLED=false
INTELLIGENT_PHASE2_ENABLED=false

INTELLIGENT_OVERVIEW_API_ENABLED=false
INTELLIGENT_INSIGHTS_ENABLED=false
INTELLIGENT_RECOMMENDATIONS_ENABLED=false
INTELLIGENT_ALERTS_ENABLED=false

INTELLIGENT_COMMAND_CENTER_ENABLED=false
INTELLIGENT_COMMAND_CENTER_GOVERNANCE_ENABLED=false

# ── Subscriptions realtime events retention ───────────────────────────
# Days to keep rows in subscription_realtime_events before prune job deletes them.
SUBSCRIPTIONS_REALTIME_RETENTION_DAYS=14

# GET /api/v1/admin/subscriptions/debug/health — فحص مؤقت؛ اتركه false في الإنتاج.
PLATFORM_SUBSCRIPTIONS_DEBUG_HEALTH=false

# ── SaaS / منصة أسس برو ───────────────────────────────────────────
# بريد (أو أكثر مفصولة بفواصل) لمشغّلي المنصة: قراءة GET /api/v1/admin/companies وتعديل كتالوج الباقات عندما يكون التالي false.
# بعد DemoPlatformAdminSeeder: platform-demo@osas.sa (اختياري — الحساب التجريبي يعتمد is_platform_user)
SAAS_PLATFORM_ADMIN_EMAILS=
# أرقام جوال (مفصولة بفواصل) لمشغّلي منصة بلا شركة (users.company_id = null) — يُطبَّع الرقم مثل مسار تسجيل الدخول بالجوال.
SAAS_PLATFORM_ADMIN_PHONES=
# عند true: يسمح لأي مالك مستأجر يملك subscriptions.manage بتعديل جدول plans العالمي (غير مُنصح لإنتاج متعدد المستأجرين).
SAAS_ALLOW_TENANT_PLAN_CATALOG_EDIT=false

# تشغيل واجهات مشغّل المنصة (/api/v1/platform/* …). عند false تُرجع المسارات 404 (إخفاء السطح).
PLATFORM_ADMIN_ENABLED=true
# دور IAM الافتراضي في account_context عند الحساب مُعرَّف بالقائمة البيضاء وplatform_role فارغ في قاعدة البيانات.
# PLATFORM_DEFAULT_WHITELIST_ROLE=platform_admin
# عند true: يطلب تسجيل الدخول رمز تحقق لمرة واحدة يُرسل إلى البريد (انظر config/saas.php).
# SAAS_LOGIN_OTP_ENABLED=false
# SAAS_LOGIN_OTP_TTL=300
# قناة رمز الدخول: email | sms | both (أي قيمة أخرى تُعاد تلقائياً إلى email)
# SAAS_LOGIN_OTP_CHANNEL=email
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=

# ── تسجيل الدخول/التسجيل برقم الجوال + OTP (مسار إضافي) ─────────────
# PHONE_OTP_TTL=300
# PHONE_OTP_MAX_ATTEMPTS=8
# PHONE_OTP_SEND_MAX_PHONE=5
# PHONE_OTP_SEND_MAX_IP=30
# في local/testing فقط: تسجيل رمز واضح للاختبار (يُعطّل تلقائياً خارجهما)
# PHONE_OTP_FAKE_PLAINTEXT=

# ── تخزين الملفات والوسائط (توسعة مستقبلية) ─────────────────────────
# القرص الافتراضي للتطبيق (Laravel): local | public | s3
# FILESYSTEM_DISK=local
#
# رفع مستندات المستأجر (شعارات، فواتير، مستندات مركبات، عقود، مشتريات…):
# public = تخزين محلي تحت storage/app/public + رابط /storage
# s3     = يتطلب league/flysystem-aws-s3-v3 + ضبط AWS_* أدناه
# MEDIA_TENANT_UPLOAD_DISK=public
#
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false
