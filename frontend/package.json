{
  "name": "saas-pos-frontend",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:og": "node scripts/generate-landing-og.mjs",
    "generate:showcase": "node scripts/generate-showcase-webp.mjs",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "capture:showcase": "node scripts/capture-showcase-screenshots.mjs",
    "build": "npm run generate:showcase && npm run generate:pwa-icons && vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:platform": "playwright test --project=chromium-platform-gate",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "npm run lint:check && npm run type-check && npm run test && npm run test:e2e",
    "policy:env": "node ../scripts/check-policy-env-example.mjs",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .vue,.ts,.tsx --max-warnings 0",
    "docs:nav-api-check": "node scripts/check-tenant-nav-api-doc.mjs",
    "docs:nav-api-dump": "node scripts/check-tenant-nav-api-doc.mjs --dump",
    "test:phase0": "npm run docs:nav-api-check && npm run test -- src/config/businessFeatureProfileDefaults.test.ts src/config/staffFeatureGate.test.ts src/utils/postLoginRedirect.test.ts src/utils/phoneOnboardingRedirect.test.ts src/config/resolveViteApiProxyTarget.test.ts src/i18n/pwaInstallLocales.test.ts",
    "test:phase1": "npm run test -- src/config/platformAdminNav.test.ts src/config/platformAdminInPageNav.test.ts src/config/platformCompanyDetailInPageNav.test.ts src/composables/usePlatformWelcomeHint.test.ts",
    "test:phase2": "npm run test -- src/utils/invoiceCreatePayment.test.ts src/utils/groupOperationsFeedByDay.test.ts src/composables/useNavigationContext.test.ts",
    "test:phase3": "npm run test -- src/constants/apiErrorCodes.test.ts src/utils/loginApiErrors.test.ts",
    "test:phase4": "npm run test -- src/utils/invoicePrintDisplay.test.ts src/utils/datetimeLocalToIso.test.ts src/utils/friendlyFieldLabel.test.ts",
    "test:phase5": "npm run test -- src/config/portalAccess.test.ts src/locales/localeParity.teamOrg.test.ts",
    "test:phase6": "npm run test -- src/types/platform-admin src/composables/platform-admin src/router/platformIntelligenceRoutesGuard.test.ts src/router/platformRoutesContract.test.ts src/components/platform-admin src/views/platform/platformViewsLoad.test.ts",
    "test:phase7": "playwright test e2e/readiness-gate-public.spec.ts e2e/auth-public.spec.ts e2e/production-real-flow.spec.ts",
    "test:phases:fe": "npm run test:phase0 && npm run test:phase1 && npm run test:phase2 && npm run test:phase3 && npm run test:phase4 && npm run test:phase5 && npm run test:phase6",
    "test:phases:fe:with-e2e": "npm run test:phases:fe && npm run test:phase7"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.0",
    "@heroicons/vue": "^2.1.0",
    "@sentry/vue": "^8.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "@vueuse/core": "^10.9.0",
    "axios": "^1.15.0",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "marked": "^18.0.0",
    "pdfjs-dist": "^4.10.38",
    "pinia": "^2.1.0",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.6"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.10",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.0"
  }
}
