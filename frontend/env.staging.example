# نسخة مرجعية لـ vite build على staging — انسخ إلى .env.production.local أو متغيرات CI.
# لا تُلزم الالتزام باسم الملف؛ المهم ضبط القيم عند البناء.

VITE_API_BASE_URL=https://staging.example.com/api/v1
VITE_APP_NAME="SaaS POS"

# يُحقَن في الحزمة — يظهر في واجهة «بيانات النشر»
VITE_DEPLOY_ENV=staging

# بوابات اختيارية: اتركه فارغاً = تفعيل customer + admin فقط.
# الإعداد المعتمد:
# VITE_ENABLED_PORTALS=customer,admin
# ملاحظة: بوابة الأسطول معطّلة قسرياً لجميع المستخدمين.

# VITE_PUBLIC_SITE_URL=https://staging.example.com
