# صفحة الهبوط (أسس برو): افتحها على نفس منفذ الواجهة — مثلاً http://localhost:5173/landing (Vite)
# أو مع Docker على المنفذ 80: http://localhost/landing — لا تفتح /landing على منفذ Laravel فقط (:8000) دون ضبط FRONTEND_PUBLIC_URL في backend/.env
# مع Vite dev + بروكسي: اترك VITE_API_BASE_URL فارغاً حتى يستخدم axios المسار النسبي /api/v1 (نفس منفذ 5173).
VITE_API_BASE_URL=
VITE_APP_NAME="أسس برو"
# اتركه فارغاً: على المضيف بدون Docker → افتراضياً http://127.0.0.1 (منفذ 80، nginx في docker compose). مع docker compose للواجهة → http://nginx.
# مع php artisan serve فقط: VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
# بعد php artisan migrate:fresh --seed في الـ backend: حساب ديمو owner@demo.sa / password — منصة admin@osas.sa / 12345678
VITE_DEV_PROXY_TARGET=
# عند استخدام ngrok مع Vite: ضع اسم المضيف فقط (بدون https://). بعد تشغيل النفق: `make ngrok-url` من جذر المشروع.
# مع Docker: انسخ `.env.example` إلى `.env` في جذر المشروع وأضف NGROK_AUTHTOKEN ثم `make ngrok-up`.
# VITE_DEV_PUBLIC_HOST=your-subdomain.ngrok-free.app
# صفحة «خريطة الفروع» — أنشئ مفتاحاً من Google Cloud Console (Maps JavaScript API)
# VITE_GOOGLE_MAPS_API_KEY=

# نشر Production: local | staging | production (يُحقَن في الحزمة عند vite build)
# VITE_DEPLOY_ENV=production

# عنوان المنشور العلني (يُفضّل مع HTTPS) لوسوم canonical و Open Graph على صفحة /landing
# عند تركه فارغًا يُستخدم window.location.origin أثناء التصفح.
# عند **vite build** مع ضبط هذا المتغير يُولَّد تلقائيًا في dist/: sitemap.xml و robots.txt (روابط /landing و /asas-pro و /asaspro).
# VITE_PUBLIC_SITE_URL=https://example.com
#
# Google Tag Manager (اختياري) — يحمّل gtm.js بعد dataLayer؛ أحداث الهبوط تُدفع تلقائيًا
# إلى dataLayer من src/utils/landingAnalytics.ts تحت الحقول event / landing_event.
# VITE_GTM_CONTAINER_ID=GTM-XXXXXXX
#
# إعادة توليد صورة المشاركة 1200×630: npm run generate:og (يحتاج devDependency sharp)
# صور WebP لمعرض مزايا الهبوط من SVG: npm run generate:showcase — أو تُولَّد تلقائيًا مع npm run build (public/landing/showcase/)
# لقطات PNG من الواجهة الفعلية (يتطلب dev + API + بيانات تجريبية): npx playwright install chromium ثم npm run capture:showcase
# تجاوز git داخل Docker/CI (اختياري):
# VITE_BUILD_GIT_COMMIT=a1b2c3d
# VITE_BUILD_GIT_BRANCH=main
# VITE_BUILD_TIME=2026-04-01T12:00:00.000Z
# VITE_APP_VERSION=1.0.1
#
# ضغط الصور قبل إرسالها للـ API (مسح لوحة، OCR، إلخ) — أبعاد JPEG
# VITE_IMAGE_UPLOAD_MAX_EDGE=1600
# VITE_IMAGE_UPLOAD_JPEG_QUALITY=0.88
#
# مركز العمليات الذكي (Phase 4) — الافتراضي في الكود: مفعّل ما لم تضع القيمة false
# تعطيل واجهة /internal/intelligence وارتباط الشريط الجانبي: VITE_INTELLIGENCE_COMMAND_CENTER=false
# VITE_INTELLIGENCE_COMMAND_CENTER=

# تعطيل الأرشفة الإلكترونية (/electronic-archive و /workshop/hr-archive) — الافتراضي مفعّل
# VITE_ELECTRONIC_ARCHIVE=false

# تفعيل «وضع مركز الخدمة السريع» افتراضياً عند أول زيارة (أوامر العمل) — يمكن للمستخدم عكسه من زر الشريط العلوي
# VITE_STAFF_COMPACT_UI=true
#
# بوابات اختيارية في الواجهة (build-time): fleet, customer, admin — مفصولة بفواصل.
# غير مضبوط أو فارغ = تفعيل الكل (السلوك الافتراضي الآمن).
# مثال لتعطيل لوحة المنصة /admin: VITE_ENABLED_PORTALS=fleet,customer
# VITE_ENABLED_PORTALS=fleet,customer,admin
#
# صفحة /platform/login — إظهار نص بيانات تجريبية (داخلية فقط؛ لا تفعّل على إنتاج علني)
# VITE_SHOW_PLATFORM_LOGIN_HINT=true
#
# صفحة /login — أزرار تعبئة حسابات تجريبية (داخلية فقط)
# VITE_SHOW_LOGIN_DEMO_HINT=true
#
# التواصل مع الدعم / مدير النظام (تُعرض في صفحة الدخول الموحّدة)
# VITE_SUPPORT_EMAIL=sales@asaspro.sa
# VITE_SUPPORT_PHONE=
# VITE_SUPPORT_WHATSAPP=9665xxxxxxxx
