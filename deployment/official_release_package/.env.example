# =============================================================================
# قالب بيئة آمن للنشر — لا تضع أسراراً حقيقية هنا ولا ترفع ملف .env إلى git
# انسخ إلى: backend/.env (لتطبيق Laravel) و/أو جذر المشروع إذا استخدمت docker-compose مع متغيرات الجذر
# =============================================================================

# ── Laravel (إلزامي تقريباً) ───────────────────────────────────────────────
APP_NAME="SaaS POS ERP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.example.com
APP_PUBLIC_URL=https://app.example.com
FRONTEND_PUBLIC_URL=https://app.example.com

APP_RELEASE_VERSION=1.0.0
APP_RELEASE_COMMIT=placeholder
APP_RELEASE_BRANCH=main
APP_RELEASE_ENV=production

# ── قاعدة البيانات PostgreSQL ────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=saas_db
DB_USERNAME=saas_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# اختبار (اتركه فارغاً في الإنتاج ما لم تُشغّل اختبارات على خادم منفصل)
TEST_DB_HOST=
TEST_DB_PORT=
TEST_DB_DATABASE=saas_test
TEST_DB_USERNAME=
TEST_DB_PASSWORD=

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── اختياري: تنبيهات دفتر الأستاذ ───────────────────────────────────────────
LEDGER_ALERT_WEBHOOK_URL=
LEDGER_ALERT_WEBHOOK_SECRET=
LEDGER_ALERT_TIMEOUT=5

# ── ZATCA ───────────────────────────────────────────────────────────────────
ZATCA_SIMULATION_MODE=true

# ── OCR / Tesseract ─────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_TESSERACT_PATH=
OCR_DEFAULT_LANG_PLATE=eng+ara
OCR_DEFAULT_LANG_DOCUMENT=ara+eng
OCR_TIMEOUT_SECONDS=90
OCR_MAX_IMAGE_BYTES=12582912
OCR_REQUIRED_LANGS=ara,eng

# ── Intelligence (عطّل في الإنتاج إن لم تُستخدم) ─────────────────────────────
INTELLIGENT_EVENTS_ENABLED=false
INTELLIGENT_EVENTS_PERSIST_ENABLED=false
INTELLIGENT_OBSERVABILITY_ENABLED=false
INTELLIGENT_INTERNAL_DASHBOARD_ENABLED=false
INTELLIGENT_READ_MODELS_ENABLED=false
INTELLIGENT_PHASE2_ENABLED=false
INTELLIGENT_OVERVIEW_API_ENABLED=false
INTELLIGENT_INSIGHTS_ENABLED=false
INTELLIGENT_RECOMMENDATIONS_ENABLED=false
INTELLIGENT_ALERTS_ENABLED=false
INTELLIGENT_COMMAND_CENTER_ENABLED=false
INTELLIGENT_COMMAND_CENTER_GOVERNANCE_ENABLED=false

# ── SaaS / منصة ─────────────────────────────────────────────────────────────
SAAS_PLATFORM_ADMIN_EMAILS=ops@example.com
SAAS_ALLOW_TENANT_PLAN_CATALOG_EDIT=false

# ── Sentry (اختياري) ───────────────────────────────────────────────────────
# SENTRY_LARAVEL_DSN=

# ── AWS S3 (اختياري — إن استُخدم تخزين وسائط على S3) ─────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# متغيرات جذر اختيارية لـ Docker Compose / ngrok (إن وُجدت في بيئتكم)
# =============================================================================
# NGROK_AUTHTOKEN=
# NGROK_DOMAIN=
